{
  "max_file_size_mb": 5,
  "chunk_size_mb": 1,
  "binary_extensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".webp",
    ".bmp",
    ".ico",
    ".svg",
    ".pdf",
    ".mp4",
    ".mov",
    ".avi",
    ".mp3",
    ".wav",
    ".zip",
    ".rar",
    ".7z",
    ".tar",
    ".gz",
    ".exe",
    ".dll",
    ".so",
    ".o",
    ".a",
    ".class",
    ".jar",
    ".pyc"
  ],
  "ignored_directories": [
    ".git",
    ".github/cache",
    "node_modules",
    "dist",
    "build",
    "target",
    "coverage",
    ".next",
    ".nuxt",
    ".cache",
    "venv",
    ".venv",
    "__pycache__",
    ".idea",
    ".vscode"
  ]
}
